# OPENROUTER_API_KEY=sk-or-...
# Optional: model slug (default: openai/gpt-4o-mini)
# OPENROUTER_MODEL=openai/gpt-4o-mini

# Recommended: GitHub token for metadata and GraphQL stats enrichment
# GITHUB_TOKEN=ghp_...

# Required: Firecrawl API key for web + GitHub search
# FIRECRAWL_API_KEY=fc-...

# Optional: write search debug logs to /logs in production (always on in dev)
# GITSIMILAR_LOG=1
